---
import NormalLayout from "~/layouts/NormalLayout.astro";
---

<NormalLayout>
  <style lang="scss">
    section {
      width: 100%;
      height: 100vh;
    }

    #top {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: var(--color-theme-2);
      & > .name {
        position: relative;
        z-index: 1;
        & > h1,
        & > .pseudo-names > .pseudo-name {
          font-family: "Josefin Sans", sans-serif;
          font-size: 24px;
          font-weight: 200;
          letter-spacing: 0.15em;
          color: var(--color-theme-1);
        }
        & > h1 {
          position: relative;
          z-index: 1;
          animation-name: main-name;
          animation-duration: 1s;
          animation-delay: 0.75s;
          animation-fill-mode: both;
          @keyframes main-name {
            0% {
              opacity: 0;
            }
            100% {
              opacity: 1;
            }
          }
        }
        & > .pseudo-names {
          position: absolute;
          inset: 0;
          & > .pseudo-name {
            position: absolute;
            width: 100%;
            height: 50%;
            overflow: hidden;
            &::after {
              content: attr(ml-name);
              position: absolute;
            }
            &:nth-of-type(1),
            &:nth-of-type(2) {
              &::after {
                animation-duration: 0.75s;
                animation-delay: 0.75s;
                animation-fill-mode: both;
                animation-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
              }
            }
            &:nth-of-type(1) {
              top: 0%;
              &::after {
                top: 0;
                animation-name: main-pseudo-name-1;
                @keyframes main-pseudo-name-1 {
                  0% {
                    transform: translateY(100%);
                  }
                  50% {
                    transform: translateY(0%);
                    opacity: 1;
                  }
                  100% {
                    transform: translateX(-5%);
                    opacity: 0;
                  }
                }
              }
            }
            &:nth-of-type(2) {
              top: 50%;
              &::after {
                bottom: 0;
                animation-name: main-pseudo-name-2;
                @keyframes main-pseudo-name-2 {
                  0% {
                    transform: translateY(-100%);
                  }
                  50% {
                    transform: translateX(0%);
                    opacity: 1;
                  }
                  100% {
                    transform: translateX(5%);
                    opacity: 0;
                  }
                }
              }
            }
          }
        }
        & > .lines {
          position: absolute;
          z-index: 0;
          top: -12.5%;
          bottom: -12.5%;
          left: -12.5%;
          right: -12.5%;
          width: 125%;
          height: 125%;
          & > .line {
            position: absolute;
            inset: 0;
            overflow: hidden;
            &::after {
              content: "";
              position: absolute;
              width: 100%;
              height: 50%;
              border-bottom: 1px solid var(--color-theme-1);
            }
            &:nth-of-type(1),
            &:nth-of-type(2),
            &:nth-of-type(3),
            &:nth-of-type(4) {
              &:after {
                animation-duration: 1s;
                animation-fill-mode: both;
                animation-timing-function: cubic-bezier(0.15, 0.94, 0.78, 0.54);
              }
            }
            &:nth-of-type(1) {
              transform-origin: 5% center;
              transform: rotateZ(45deg);
              &:after {
                transform-origin: right;
                animation-name: main-name-lines-1;
                @keyframes main-name-lines-1 {
                  0% {
                    transform: translateX(100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(0.5);
                  }
                  100% {
                    transform: translateX(calc(-100% - 1px)) scaleX(1);
                  }
                }
              }
            }
            &:nth-of-type(2) {
              transform-origin: 5% center;
              transform: rotateZ(-45deg);
              &:after {
                animation-name: main-name-lines-2;
                transform-origin: right;
                @keyframes main-name-lines-2 {
                  0% {
                    transform: translateX(100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(0.5);
                  }
                  100% {
                    transform: translateX(calc(-100% - 1px)) scaleX(1);
                  }
                }
              }
            }
            &:nth-of-type(3) {
              transform-origin: 95% center;
              transform: rotateZ(45deg);
              &:after {
                animation-name: main-name-lines-3;
                transform-origin: left;
                @keyframes main-name-lines-3 {
                  0% {
                    transform: translateX(-100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(0.5);
                  }
                  100% {
                    transform: translateX(calc(100% + 1px)) scaleX(1);
                  }
                }
              }
            }
            &:nth-of-type(4) {
              transform-origin: 95% center;
              transform: rotateZ(-45deg);
              &:after {
                animation-name: main-name-lines-4;
                transform-origin: left;
                @keyframes main-name-lines-4 {
                  0% {
                    transform: translateX(-100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(0.5);
                  }
                  100% {
                    transform: translateX(calc(100% + 1px)) scaleX(1);
                  }
                }
              }
            }
            &:nth-of-type(5),
            &:nth-of-type(6) {
              &:after {
                animation-delay: 0.75s;
                animation-duration: 0.5s;
                animation-fill-mode: both;
                animation-timing-function: cubic-bezier(
                  0.875,
                  0.14,
                  0.035,
                  0.915
                );
              }
            }
            &:nth-of-type(5) {
              transform-origin: right center;
              width: 50%;
              left: -12.5%;
              &:after {
                animation-name: main-name-lines-5;
                transform-origin: right;
                @keyframes main-name-lines-5 {
                  0% {
                    transform: translateX(100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(1);
                  }
                  100% {
                    transform: translateX(-100%);
                  }
                }
              }
            }
            &:nth-of-type(6) {
              transform-origin: right center;
              left: 62.5%;
              width: 50%;
              &:after {
                animation-name: main-name-lines-6;
                transform-origin: left;
                @keyframes main-name-lines-6 {
                  0% {
                    transform: translateX(-100%) scaleX(0);
                  }
                  50% {
                    transform: translateX(0%) scaleX(1);
                  }
                  100% {
                    transform: translateX(100%);
                  }
                }
              }
            }
          }
        }
      }
      & > .sitename {
        margin-top: 8px;
        position: relative;
        $chars-common-delay: 750ms;
        $chars-delay-range: 250ms;
        $chars-duration: 0.5s;
        z-index: 1;
        & > p,
        & > .chars > .char {
          color: var(--color-theme-1);
          font-family: "Silkscreen", sans-serif;
          font-size: 12px;
          letter-spacing: 0.125em;
        }
        & > p {
          animation-name: main-sitename;
          animation-fill-mode: both;
          animation-delay: (
            $chars-common-delay + $chars-delay-range + $chars-duration
          );
          @keyframes main-sitename {
            0% {
              visibility: hidden;
              opacity: 0;
            }
            100% {
              visibility: visible;
              opacity: 1;
            }
          }
        }
        & > .chars {
          position: absolute;
          top: 0;
          left: 0;
          display: flex;
          overflow: hidden;

          animation-name: main-sitename-chars;
          animation-fill-mode: both;
          animation-delay: (
            $chars-common-delay + $chars-delay-range + $chars-duration
          );
          @keyframes main-sitename-chars {
            0% {
              opacity: 1;
              visibility: visible;
            }
            100% {
              opacity: 0;
              visibility: hidden;
            }
          }

          & > .char {
            animation-duration: $chars-duration;
            animation-fill-mode: both;
            animation-timing-function: cubic-bezier(0.345, 0.095, 0, 0.995);
            @keyframes main-sitename-chars-b {
              0% {
                transform: translateY(100%);
              }
              100% {
                transform: translateY(0);
              }
            }
            @keyframes main-sitename-chars-t {
              0% {
                transform: translateY(-100%);
              }
              100% {
                transform: translateY(0);
              }
            }
            &::after {
              content: attr(ml-char);
            }
            &:nth-of-type(1) {
              animation-delay: $chars-common-delay + (0.16 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
            &:nth-of-type(2) {
              animation-delay: $chars-common-delay + (0.52 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(3) {
              animation-delay: $chars-common-delay + (0.46 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(4) {
              animation-delay: $chars-common-delay + (0.23 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
            &:nth-of-type(5) {
              animation-delay: $chars-common-delay + (-0.1 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(6) {
              animation-delay: $chars-common-delay + (0.69 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
            &:nth-of-type(7) {
              animation-delay: $chars-common-delay + (0.75 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(8) {
              animation-delay: $chars-common-delay + (0.87 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
            &:nth-of-type(9) {
              animation-delay: $chars-common-delay + (0.72 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
            &:nth-of-type(10) {
              animation-delay: $chars-common-delay + (0.65 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(11) {
              animation-delay: $chars-common-delay + (0.43 * $chars-delay-range);
              animation-name: main-sitename-chars-t;
            }
            &:nth-of-type(12) {
              animation-delay: $chars-common-delay + (0.32 * $chars-delay-range);
              animation-name: main-sitename-chars-b;
            }
          }
        }
      }
      & > .decoboxes-1 {
        position: absolute;
        inset: 0;
        & > .deco {
          position: absolute;
          $size: 24px;
          width: $size;
          height: $size;
          border: solid var(--color-theme-1);
          border-width: ($size/2);
          animation-name: main-decobox-1;
          animation-fill-mode: both;
          animation-duration: 0.25s;
          animation-delay: 750ms;
          @keyframes main-decobox-1 {
            0% {
              transform: scale(0);
            }
            50% {
              transform: scale(1);
              border-width: ($size/2);
            }
            100% {
              border-width: 0;
              transform: scale(1.25);
            }
          }
          &:nth-of-type(1) {
            top: 16px;
            left: 16px;
          }
          &:nth-of-type(2) {
            top: 16px;
            right: 16px;
          }
          &:nth-of-type(3) {
            bottom: 16px;
            right: 16px;
          }
          &:nth-of-type(4) {
            bottom: 16px;
            left: 16px;
          }
        }
      }
      & > .decolines-1 {
        position: absolute;
        inset: 0;
        @keyframes main-decolines-1-1 {
          0% {
            transform: translateX(0) scaleX(0);
            opacity: 0;
          }
          25% {
            opacity: 1;
          }
          50% {
            transform: translateX(0) scaleX(1);
          }
          100% {
            transform: translateX(-100%) scaleX(0);
          }
        }
        @keyframes main-decolines-1-2 {
          0% {
            transform: translateX(0) scaleX(0);
            opacity: 0;
          }
          25% {
            opacity: 1;
          }
          50% {
            transform: translateX(0) scaleX(1);
          }
          100% {
            transform: translateX(100%) scaleX(0);
          }
        }
        @keyframes main-decolines-1-3 {
          0% {
            transform: translateY(0) scaleY(0);
            opacity: 0;
          }
          25% {
            opacity: 1;
          }
          50% {
            transform: translateY(0) scaleY(1);
          }
          100% {
            transform: translateY(-100%) scaleY(0);
          }
        }
        @keyframes main-decolines-1-4 {
          0% {
            transform: translateY(0) scaleY(0);
            opacity: 0;
          }
          25% {
            opacity: 1;
          }
          50% {
            transform: translateY(0) scaleY(1);
          }
          100% {
            transform: translateY(100%) scaleY(0);
          }
        }
        & > .lines {
          position: absolute;
          overflow: hidden;
          & > .line {
            position: absolute;
            animation-timing-function: cubic-bezier(0.94, 0.12, 0, 0.995);
            animation-fill-mode: both;
            animation-duration: 0.75s;
          }
          &:nth-of-type(1),
          &:nth-of-type(2) {
            width: calc(100vw - 128px);
            height: 1px;
            & > .line {
              top: 0;
              width: 50%;
              height: 100%;
              border-bottom: 1px solid var(--color-theme-1);
              &:nth-of-type(1) {
                left: -8px;
                animation-name: main-decolines-1-1;
                transform-origin: right;
              }
              &:nth-of-type(2) {
                left: calc(50% + 8px);
                animation-name: main-decolines-1-2;
                transform-origin: left;
              }
            }
          }
          &:nth-of-type(3),
          &:nth-of-type(4) {
            height: calc(100vh - 128px);
            width: 1px;
            & > .line {
              top: 0;
              width: 100%;
              height: 50%;
              border-right: 1px solid var(--color-theme-1);
              &:nth-of-type(1) {
                top: -8px;
                animation-name: main-decolines-1-3;
                transform-origin: bottom;
              }
              &:nth-of-type(2) {
                top: calc(50% + 8px);
                animation-name: main-decolines-1-4;
                transform-origin: top;
              }
            }
          }
          &:nth-of-type(1) {
            top: 16px;
            left: 64px;
            & > .line:nth-of-type(1) {
              animation-delay: 0.25s;
            }
            & > .line:nth-of-type(2) {
              animation-delay: 0.25s;
            }
          }
          &:nth-of-type(2) {
            bottom: 16px;
            left: 64px;
            & > .line:nth-of-type(1) {
              animation-delay: 0.25s;
            }
            & > .line:nth-of-type(2) {
              animation-delay: 0.25s;
            }
          }
          &:nth-of-type(3) {
            top: 64px;
            left: 16px;
            & > .line:nth-of-type(1) {
              animation-delay: 0.45s;
            }
            & > .line:nth-of-type(2) {
              animation-delay: 0.45s;
            }
          }
          &:nth-of-type(4) {
            top: 64px;
            right: 16px;
            & > .line:nth-of-type(1) {
              animation-delay: 0.45s;
            }
            & > .line:nth-of-type(2) {
              animation-delay: 0.45s;
            }
          }
        }
      }
    }
  </style>

  <main>
    <section id="top">
      <div class="name">
        <h1>SnO2WMaN</h1>
        <div class="pseudo-names">
          <div class="pseudo-name" ml-name="SnO2WMaN"></div>
          <div class="pseudo-name" ml-name="SnO2WMaN"></div>
        </div>
        <div class="lines">
          <div class="line"></div>
          <div class="line"></div>
          <div class="line"></div>
          <div class="line"></div>
          <div class="line"></div>
          <div class="line"></div>
        </div>
      </div>
      <div class="sitename">
        <p>sno2wman.net</p>
        <div class="chars">
          <span class="char" ml-char="s"></span>
          <span class="char" ml-char="n"></span>
          <span class="char" ml-char="o"></span>
          <span class="char" ml-char="2"></span>
          <span class="char" ml-char="w"></span>
          <span class="char" ml-char="m"></span>
          <span class="char" ml-char="a"></span>
          <span class="char" ml-char="n"></span>
          <span class="char" ml-char="."></span>
          <span class="char" ml-char="n"></span>
          <span class="char" ml-char="e"></span>
          <span class="char" ml-char="t"></span>
        </div>
      </div>
      <div class="decoboxes-1">
        <div class="deco"></div>
        <div class="deco"></div>
        <div class="deco"></div>
        <div class="deco"></div>
      </div>
      <div class="decolines-1">
        <div class="lines">
          <div class="line"></div>
          <div class="line"></div>
        </div>
        <div class="lines">
          <div class="line"></div>
          <div class="line"></div>
        </div>
        <div class="lines">
          <div class="line"></div>
          <div class="line"></div>
        </div>
        <div class="lines">
          <div class="line"></div>
          <div class="line"></div>
        </div>
      </div>
    </section>
  </main>
</NormalLayout>
